// Resource script for Windows Agent — icon + settings dialog.
#include <windows.h>
#include "resource.h"

IDI_APPICON ICON "app.ico"

// comctl32 v6 visual styles + system DPI awareness (see agent.manifest).
1 24 "agent.manifest"

IDD_AGENT_SETTINGS DIALOGEX 0, 0, 320, 160
CAPTION "Agent settings"
FONT 9, "Segoe UI"
BEGIN
    LTEXT        "Device ID",    -1,  10, 12, 80, 14
    EDITTEXT     IDC_AS_DEVICE, 100, 10, 200, 14, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT        "Server host",  -1,  10, 36, 80, 14
    EDITTEXT     IDC_AS_HOST,   100, 34, 200, 14, ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT        "Server port",  -1,  10, 60, 80, 14
    EDITTEXT     IDC_AS_PORT,   100, 58,  80, 14, ES_NUMBER | WS_TABSTOP
    LTEXT        "(settings are saved to agent.json)", -1,
                 10, 88, 280, 14
    DEFPUSHBUTTON "OK",          IDOK,  160, 116, 70, 24, WS_TABSTOP
    PUSHBUTTON   "Cancel",      IDCANCEL, 240, 116, 70, 24, WS_TABSTOP
END

IDD_AGENT_ABOUT DIALOGEX 0, 0, 320, 140
CAPTION "About Agent"
FONT 9, "Segoe UI"
BEGIN
    ICON         IDI_APPICON,    -1,  16, 16, 32, 32, SS_ICON
    LTEXT        "RemoteTool Agent", -1, 60, 18, 200, 18, SS_LEFT
    LTEXT        "Reverse tunnel client", -1, 60, 36, 240, 30
    LTEXT        "Version 0.1.0", -1, 60, 70, 200, 14
    DEFPUSHBUTTON "OK",           IDOK, 230, 100, 70, 24, WS_TABSTOP
END
